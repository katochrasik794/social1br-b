DATABASE_URL="postgresql://USER:PASSWORD@HOST/social1br?sslmode=require"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"
OTP_TTL_MINUTES=10
PORT=5001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Dev OTP bypass (skip SMTP, always use fixed OTP)
DEV_OTP_ENABLED=true
DEV_OTP=123456

# SMTP (production / when DEV_OTP_ENABLED=false)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Social Trading <noreply@example.com>"

# Initial super admin (seed)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD="change-me-strong"

# MT5 API base URL only (manager creds stored in DB after seed)
MT5_API_URL=https://www.thefincrm.net
MT5_MANAGER_TOKEN_TTL_MS=240000

# One-time seed only — remove after running npm run db:seed
# MT5_MANAGER_API_KEY=
# MT5_MANAGER_LOGIN=
# MT5_MANAGER_PASSWORD=
# MT5_MANAGER_SERVER=
